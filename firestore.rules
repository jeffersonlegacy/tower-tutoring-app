rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthed() {
      return request.auth != null;
    }

    // Leaderboards are public-read, authenticated-write.
    match /leaderboards/{gameId}/scores/{scoreId} {
      allow read: if true;
      allow write: if isAuthed();
    }

    // Session and whiteboard data requires auth.
    match /sessions/{sessionId} {
      allow read, write: if isAuthed();
    }

    match /whiteboards/{sessionId} {
      allow read, write: if isAuthed();
      match /{document=**} {
        allow read, write: if isAuthed();
      }
    }

    // Default auth requirement for any remaining collection.
    match /{document=**} {
      allow read, write: if isAuthed();
    }
  }
}
