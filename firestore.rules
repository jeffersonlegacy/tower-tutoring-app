rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthed() {
      return request.auth != null;
    }

    function readSessionOwner(sessionId, resource) {
      let owner = resource?.data?.ownerId;
      if (!owner) {
        owner = get(/databases/$(database)/documents/sessions/$(sessionId)).data.ownerId;
      }
      return owner || null;
    }

    function isSessionOwner(sessionId, resource) {
      const owner = readSessionOwner(sessionId, resource);
      return isAuthed() && owner != null && owner == request.auth.uid;
    }

    // Leaderboards: public-read, authenticated writes with minimal vetting.
    match /leaderboards/{gameId}/scores/{scoreId} {
      allow read: if true;
      allow write: if isAuthed()
        && request.resource.data.towerTag is string
        && request.resource.data.score is number;
    }

    match /sessions/{sessionId} {
      allow create: if isAuthed()
        && request.resource.data.ownerId == request.auth.uid;
      allow read: if isAuthed() && (readSessionOwner(sessionId, resource) == null || readSessionOwner(sessionId, resource) == request.auth.uid);
      allow update, delete: if isSessionOwner(sessionId, resource);
    }

    match /whiteboards/{sessionId} {
      allow read: if isAuthed() && (readSessionOwner(sessionId, resource) == null || readSessionOwner(sessionId, resource) == request.auth.uid);
      allow write: if isSessionOwner(sessionId);
      match /{document=**} {
        allow read: if isAuthed() && (readSessionOwner(sessionId, resource) == null || readSessionOwner(sessionId, resource) == request.auth.uid);
        allow write: if isSessionOwner(sessionId);
      }
    }

    // Default deny for everything else except authenticated reads.
    match /{document=**} {
      allow read: if isAuthed();
      allow write: if false;
    }
  }
}
